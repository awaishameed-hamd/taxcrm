# Application
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/ca_firm_crm?schema=public"

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-here
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourfirm.com
RESEND_FROM_NAME=CA Firm CRM

# Client URL (for CORS and email links)
CLIENT_URL=http://localhost:3000

# Socket.IO CORS
SOCKET_CORS_ORIGIN=http://localhost:3000
