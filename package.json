{
  "name": "ca-firm-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "dev:api": "turbo run dev --filter=@ca-firm/api",
    "dev:web": "turbo run dev --filter=@ca-firm/web",
    "db:generate": "turbo run db:generate --filter=@ca-firm/api",
    "db:migrate": "turbo run db:migrate --filter=@ca-firm/api",
    "db:studio": "turbo run db:studio --filter=@ca-firm/api"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
